# ==============================================================
# CandidateVoice — Environment Variables Template
# ==============================================================
# INSTRUCTIONS:
#   1. Copy this file: cp .env.example .env.local
#   2. Fill in your actual values in .env.local
#   3. NEVER commit .env.local or any file with real keys
#   4. .env.local is already in .gitignore
# ==============================================================

# --------------------------------------------------------------
# SUPABASE — Required
# Get these from: https://app.supabase.com → Project → Settings → API
# --------------------------------------------------------------

# Your Supabase project URL (safe to expose in frontend)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon key — public, safe to ship in frontend bundle
# This key enforces RLS — users only see what policies allow
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key — DANGEROUS. Server-side ONLY.
# Has full DB access, bypasses RLS. NEVER expose to client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --------------------------------------------------------------
# CONTENT MODERATION — Required for submission pipeline
# Hive Moderation: https://hivemoderation.com
# --------------------------------------------------------------

HIVE_API_KEY=your-hive-api-key-here

# --------------------------------------------------------------
# APP CONFIG
# --------------------------------------------------------------

# Canonical URL of the app (used for redirects, OG tags, etc.)
# Local dev: http://localhost:3000
# Production: https://candidatevoice.io
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --------------------------------------------------------------
# OPTIONAL — Future phases
# --------------------------------------------------------------

# Analytics (Phase 6)
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=

# Email (Phase 4 — admin notifications)
# RESEND_API_KEY=
